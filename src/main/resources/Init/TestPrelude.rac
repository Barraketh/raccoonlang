def Sort (l: Level): Type := builtin

namespace Level {
  def succ (l: Level): Level := builtin

  def max (l1: Level)(l2: Level): Level := builtin
}

def add_normalizer (zero: $A of Type)(add: A -> A -> A): Normalizer := builtin

inductive Eq indices (x: $A of Sort($u))(y: A) : Prop
 | refl (x: $A of Sort($u)) : Eq(x, x)
